---
// Renders CMS-created Dutch pages (Keystatic → src/content/pages/nl/*) at /<slug>/.
// File-based routes outrank Starlight's injected [...slug], and the two generate
// disjoint paths, so /docs/… stays Starlight's.
import { getCollection, render } from 'astro:content';
import SiteShell from '../components/SiteShell.astro';
import settings from '../data/settings/site.json';

export async function getStaticPaths() {
  const pages = await getCollection('pages', (entry) => entry.id.startsWith('nl/'));
  return pages.map((entry) => ({
    params: { slug: entry.id.slice('nl/'.length) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<SiteShell
  locale="nl"
  title={`${entry.data.title} · ${settings.brandName}`}
  description={entry.data.description}
>
  <article class="container page prose">
    <h1>{entry.data.title}</h1>
    <Content />
  </article>
</SiteShell>
