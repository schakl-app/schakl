---
// Renders CMS-created English pages (Keystatic → src/content/pages/en/*) at /en/<slug>/.
import { getCollection, render } from 'astro:content';
import SiteShell from '../../components/SiteShell.astro';
import settings from '../../data/settings/site.json';

export async function getStaticPaths() {
  const pages = await getCollection('pages', (entry) => entry.id.startsWith('en/'));
  return pages.map((entry) => ({
    params: { slug: entry.id.slice('en/'.length) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<SiteShell
  locale="en"
  title={`${entry.data.title} · ${settings.brandName}`}
  description={entry.data.description}
>
  <article class="container page prose">
    <h1>{entry.data.title}</h1>
    <Content />
  </article>
</SiteShell>
