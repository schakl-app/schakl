---
// A marketing form page: hero (title + intro), a success banner (shown after the backend
// redirects with ?sent=1), the CMS-defined form, and — for the contact form — an aside with
// other ways to reach us. Pure presentation; submission is handled by /api/forms later.
import SiteShell from './SiteShell.astro';
import FormRenderer from './FormRenderer.astro';
import settings from '../data/settings/site.json';

interface Props {
  locale: 'nl' | 'en';
  form: any;
}
const { locale, form } = Astro.props;
const title = `${settings.brandName} · ${form.title[locale]}`;
const isContact = form.slug === 'contact';
const contactEmail = (form.recipient ?? '').trim();
const t = {
  other: locale === 'nl' ? 'Andere manieren' : 'Other ways to reach us',
  email: locale === 'nl' ? 'Mail ons' : 'Email us',
  github: 'GitHub',
  docs: locale === 'nl' ? 'Lees de documentatie' : 'Read the docs',
};
---

<SiteShell locale={locale} title={title} description={form.intro[locale]}>
  <div class="formpage container">
    <header class="formpage__hero">
      <h1>{form.title[locale]}</h1>
      <p class="subtitle">{form.intro[locale]}</p>
    </header>

    <div class="formpage__ok" data-form-ok hidden>
      {form.successMessage[locale]}
    </div>

    <div class={`formpage__body ${isContact ? 'is-split' : ''}`}>
      <div class="formpage__form">
        <FormRenderer locale={locale} form={form} />
      </div>

      {
        isContact && (
          <aside class="formpage__aside">
            <h2>{t.other}</h2>
            <ul>
              {contactEmail && (
                <li>
                  <a href={`mailto:${contactEmail}`}>{t.email}</a>
                  <span class="muted">{contactEmail}</span>
                </li>
              )}
              <li>
                <a href={settings.social?.github} target="_blank" rel="noopener">{t.github}</a>
                <span class="muted">github.com/schakl-app</span>
              </li>
              <li>
                <a href={locale === 'nl' ? '/nl/docs/' : '/en/docs/'}>{t.docs}</a>
              </li>
            </ul>
          </aside>
        )
      }
    </div>
  </div>
</SiteShell>

<style>
  .formpage {
    max-width: 56rem;
    padding-block: 3rem 5rem;
  }
  .formpage__hero {
    max-width: 40rem;
    margin-bottom: 2rem;
  }
  .formpage__hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
  }
  .formpage__hero .subtitle {
    margin-inline: 0;
  }
  .formpage__ok {
    margin-bottom: 2rem;
    padding: 1rem 1.25rem;
    border: 1px solid color-mix(in srgb, #16a34a 45%, transparent);
    background: color-mix(in srgb, #16a34a 10%, transparent);
    border-radius: 0.7rem;
    color: var(--text);
    font-weight: 550;
  }
  .formpage__body {
    display: grid;
    gap: 2.5rem;
  }
  .formpage__body.is-split {
    grid-template-columns: 1fr;
  }
  @media (min-width: 760px) {
    .formpage__body.is-split {
      grid-template-columns: 1.4fr 1fr;
      align-items: start;
    }
  }
  .formpage__form {
    max-width: 34rem;
  }
  .formpage__aside {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 0.9rem;
    background: var(--bg-soft);
  }
  .formpage__aside h2 {
    font-size: 1rem;
    margin: 0 0 1rem;
  }
  .formpage__aside ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.9rem;
  }
  .formpage__aside li {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .formpage__aside a {
    color: var(--accent);
    font-weight: 600;
  }
  .formpage__aside a:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .formpage__aside .muted {
    color: var(--muted);
    font-size: 0.85rem;
  }
</style>

<script>
  // The backend (/api/forms) redirects here with ?sent=1 on success; reveal the banner and
  // clear the query so a refresh doesn't keep showing it. Until the backend exists this is inert.
  const params = new URLSearchParams(location.search);
  if (params.get('sent') === '1') {
    const ok = document.querySelector<HTMLElement>('[data-form-ok]');
    if (ok) {
      ok.hidden = false;
      ok.scrollIntoView({ block: 'center', behavior: 'smooth' });
    }
    history.replaceState(null, '', location.pathname);
  }
</script>
