{
  "name": "@schakl/site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-cms": "cp node_modules/@sveltia/cms/dist/sveltia-cms.js public/sveltia/sveltia-cms.js",
    "dev": "pnpm run sync-cms && astro dev",
    "cms": "pnpm run sync-cms && astro dev",
    "build": "pnpm run sync-cms && astro build && pagefind --site dist",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.36.0",
    "@sveltia/cms": "^0.170.5",
    "astro": "^5.7.0"
  },
  "devDependencies": {
    "pagefind": "^1.3.0"
  }
}
