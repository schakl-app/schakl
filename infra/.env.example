# Copy to infra/.env and edit. All app config is SCHAKL_* (see apps/api/app/config.py).
# Never commit real secrets.

# --- Database (admin/bootstrap superuser) ---
POSTGRES_ADMIN_USER=schakl
POSTGRES_ADMIN_PASSWORD=schakl
POSTGRES_DB=schakl

# --- Application DB role (NON-superuser, so RLS is enforced) ---
APP_DB_USER=schakl_app
APP_DB_PASSWORD=change-me-app-db-password

# --- Runtime ---
SCHAKL_ENVIRONMENT=development
# REQUIRED. Signs sessions/reset tokens/impersonation grants and derives the at-rest encryption
# key — a known value here means anyone can forge a session for any user and decrypt every stored
# secret. Compose refuses to start if this is unset, and the API refuses to boot on a weak/known
# value when SCHAKL_ENVIRONMENT=production. Generate a unique one: `openssl rand -hex 32`.
# The dev placeholder below only works while SCHAKL_ENVIRONMENT=development.
SCHAKL_SECRET_KEY=dev-only-secret-change-me-openssl-rand-hex-32
# <slug>.<base_domain> or a custom domain resolves to an org.
SCHAKL_BASE_DOMAIN=localhost

# --- First run ---
# A fresh install is provisioned via the first-run wizard: open the app in a browser and it
# routes to /setup (org, owner account, branding, locale). There is no seed step.

# --- Instance administration (issue #26) ---
# Cross-tenant admin surface (org lifecycle, impersonation, export/import). Off by default:
# a single-tenant box has no business exposing it. Instance owners (is_superuser) only.
# SCHAKL_INSTANCE_ADMIN_ENABLED=false

# --- Public demo mode (issue #141) ---
# Turns this instance into a public, publicly-writable demo. Off by default. When on it FORCES the
# safe posture regardless of the settings above — registration off, instance admin + impersonation
# off, /setup locked — and a central guard blocks outbound/credential/instance operations. Only run
# it behind Cloudflare + a Traefik rate-limit, with no SMTP creds on the box (see docs/DEPLOY.md).
# SCHAKL_DEMO_MODE=false
# How often the demo org resets to its golden snapshot, in minutes.
# SCHAKL_DEMO_RESET_MINUTES=60

# --- Image tag for pulled images (release) ---
SCHAKL_TAG=latest

# --- Traefik host ports ---
# Production uses 80. For rootless podman (can't bind <1024), use a high port and browse
# http://app.localhost:8080
# TRAEFIK_HTTP_PORT=8080
# TRAEFIK_DASHBOARD_PORT=8081

# --- Single sign-on (OIDC) ---
# Configured IN THE APP since #76: Instellingen -> Single sign-on (per organization, secret
# encrypted at rest). No env vars needed; existing SCHAKL_OIDC_* values are seeded into the
# database once by the upgrade migration and ignored afterwards. See docs/SSO.md.
# Break-glass: re-enable local password login regardless of any org's "require SSO" setting.
# SCHAKL_FORCE_LOCAL_LOGIN=false

# --- Google (Workspace + marketing: GA4 / Search Console / Ads) ---
# The OAuth client is normally configured per-organization in the app (Instellingen -> Google,
# stored encrypted in the DB and read by both api and worker). These are the documented env
# fallback if you prefer a single instance-wide client. See docs/GOOGLE.md.
# SCHAKL_GOOGLE_CLIENT_ID=
# SCHAKL_GOOGLE_CLIENT_SECRET=
# Google Ads needs a per-agency developer token (Google Ads -> API Center; Basic access reads
# your own accounts). It is instance-level with no in-app field, so it can ONLY be set here.
# Leave empty and the marketing module's Ads source shows a "not configured" state; GA4 and
# Search Console work without it.
# SCHAKL_GOOGLE_ADS_DEVELOPER_TOKEN=
