# --- Python / API ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage

# --- Node / Web ---
node_modules/
.svelte-kit/
build/
dist/
.vite/
*.tsbuildinfo

# Paraglide is generated from messages/*.json
apps/web/src/lib/paraglide/

# Intermediate OpenAPI spec (regenerated by scripts/gen-client.sh); the typed
# client schema.d.ts IS committed.
apps/web/openapi.json

# --- Playwright ---
# Browsers live in ~/.cache/ms-playwright, not here. These are per-run artifacts.
test-results/
playwright-report/
blob-report/
.playwright/
# Playwright MCP writes per-run console logs + page snapshots here.
.playwright-mcp/

# --- Env / secrets ---
.env
.env.*
!.env.example
infra/.env
!infra/.env.example

# --- Editor / OS ---
.DS_Store
.idea/
.vscode/
*.log

# --- Local container/data volumes ---
infra/data/

# Cloudflare Tunnel credentials: `cloudflared tunnel create` writes <TUNNEL_ID>.json here.
# It is a long-lived secret for the tunnel — never commit it.
infra/cloudflared/*.json

# --- Local dev artifacts (never committed) ---
# Manual recovery stashes (patch/tarball backups of in-flight work).
.recovery/
# One-off screenshots dropped in the repo root while iterating.
email-templates-editor.png
# Vendored Sveltia CMS bundle for the site admin — a build/vendor artifact, not source.
apps/site/public/admin/sveltia-cms.js
